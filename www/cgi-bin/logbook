    color: #333;
    text-align: center;
    margin: 1.5em 0;
    font-size: 0.8em;
    /*letter-spacing: 0.3em;*/
    user-select: none;
}
.view-toggle {
    display: flex;
    gap: 0.4em;
    margin-bottom: 1.2em;
}
.view-toggle a {
    color: #7a6494;
    text-decoration: none;
    padding: 0.4em 0.9em;
