    font-weight: normal;
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2em 1em;
    box-sizing: border-box;
}
.container {
    max-width: 600px;
    width: 100%;
    display: flex;
    flex-direction: column;
    flex: 1;
}
h1 {
    font-weight: normal;
    font-size: 2.8em;
    margin: 0 0 1.2em 0;
    letter-spacing: 0.02em;
}
form {
    display: flex;
    flex-direction: column;
    gap: 0.8em;
}
label { color: #7a6494; font-size: 0.9em; }
textarea {
    background: #11111e;
    color: #c9b0ff;
    border: 1px solid #473769;
    border-radius: 3px;
    padding: 0.8em 1em;
    font-family: inherit;
    font-size: 1em;
    resize: vertical;
    min-height: 5em;
    outline: none;
    box-sizing: border-box;
    width: 100%;
}
textarea::placeholder { color: #444; }
textarea:focus { border-color: #c9b0ff; }
button {
    background: #473769;
    color: #c9b0ff;
