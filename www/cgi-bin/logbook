#!/bin/bash
# logbook - a tiny cgi logbook for ymawky
#
# install:
#   1. save as www/cgi-bin/logbook (no extension)
#   2. chmod +x www/cgi-bin/logbook
#   3. visit http://localhost:PORT/cgi-bin/logbook
#
# entries are stored in ./logbook.dat (next to this script — the cgi handler
# chdirs into the script's directory before exec, so relative paths work).
# if you rename the script, update SCRIPT_PATH below to match the URL path
# it's accessible at, so the form posts to the right place.
#
# query string params:
#   ?view=latest   (default) show only the most recent entry
#   ?view=all      show every entry, newest first
#   unknown values silently default to latest

SCRIPT_PATH="/cgi-bin/logbook"
LOGFILE="./logbook.dat"

touch "$LOGFILE" 2>/dev/null

url_decode() {
    local data="${1//+/ }"
    data="${data//\\/\\\\}"
    printf '%b' "${data//%/\\x}"
}

html_escape() {
    local s="$1"
    s="${s//&/&amp;}"
    s="${s//</&lt;}"
    s="${s//>/&gt;}"
    s="${s//\"/&quot;}"
    s="${s//\'/&#39;}"
    printf '%s' "$s"
}

parse_view() {
    local qs="$1"
    local result="latest"
    if [ -n "$qs" ]; then
        local pair v
        IFS='&' read -ra qpairs <<< "$qs"
        for pair in "${qpairs[@]}"; do
            if [[ "$pair" == view=* ]]; then
                v="${pair#view=}"
                if [ "$v" = "all" ] || [ "$v" = "latest" ]; then
                    result="$v"
                fi
                break
            fi
        done
    fi
    printf '%s' "$result"
}

view=$(parse_view "$QUERY_STRING")

# ─── POST: add a new entry ─────────────────────────────────────
if [ "$REQUEST_METHOD" = "POST" ]; then
    body=$(cat)

    entry_raw=""
    IFS='&' read -ra pairs <<< "$body"
    for pair in "${pairs[@]}"; do
        if [[ "$pair" == entry=* ]]; then
            entry_raw="${pair#entry=}"
            break
        fi
    done

    entry=$(url_decode "$entry_raw")

    entry="${entry#"${entry%%[![:space:]]*}"}"
    entry="${entry%"${entry##*[![:space:]]}"}"

    if [ -n "$entry" ]; then
        entry_clean=$(printf '%s' "$entry" | tr '\n\r\t' '   ' | tr -s ' ')
        timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        printf '%s | %s\n' "$timestamp" "$entry_clean" >> "$LOGFILE"
    fi

    printf 'Status: 303 See Other\r\n'
    printf 'Location: %s?view=%s\r\n' "$SCRIPT_PATH" "$view"
    printf '\r\n'
    exit 0
fi

# ─── GET: render form + entries ────────────────────────────────
total_entries=$(wc -l < "$LOGFILE" 2>/dev/null | tr -d ' ')
total_entries=${total_entries:-0}

printf 'Content-Type: text/html; charset=utf-8\r\n\r\n'

cat <<'HTML_HEAD'
<!DOCTYPE html>
<html>
<head>
<title>logbook</title>
<style>
