<h1>logbook</h1>
HTML_HEAD

# entry form first
cat <<HTML_FORM
<form action="${SCRIPT_PATH}?view=${view}" method="POST">
<label for="entry">new entry:</label>
<textarea name="entry" id="entry" autofocus required placeholder="what happened?"></textarea>
<button type="submit">commit to log</button>
</form>

<div class="divider"> &lt;:3&nbsp;&nbsp;&nbsp;)~~~&nbsp;&nbsp;&lt;:3&nbsp;&nbsp;&nbsp;)~~~&nbsp;&nbsp;&lt;:3&nbsp;&nbsp;&nbsp;)~~~&nbsp;&nbsp;&lt;:3&nbsp;&nbsp;&nbsp)~~~ </div>
HTML_FORM

# view toggle (with count in the latest button)
latest_class=""
all_class=""
if [ "$view" = "latest" ]; then latest_class="active"; else all_class="active"; fi
printf '<div class="view-toggle">'
printf '<a href="%s?view=latest" class="%s">view latest of %s</a>' "$SCRIPT_PATH" "$latest_class" "$total_entries"
printf '<a href="%s?view=all" class="%s">view all</a>' "$SCRIPT_PATH" "$all_class"
printf '</div>\n'

# entries
if [ "$view" = "all" ]; then
    if [ "$total_entries" -gt 0 ]; then
        printf '<div class="entries-list">\n'
        tail -r "$LOGFILE" | while IFS= read -r line; do
            entry_time="${line% | *}"
            entry_text="${line#* | }"
            printf '<div class="entry"><div class="ts">%s</div><div class="text">%s</div></div>\n' \
                "$(html_escape "$entry_time")" "$(html_escape "$entry_text")"
        done
        printf '</div>\n'
    else
        printf '<div class="empty">no entries yet — write the first one</div>\n'
    fi
else
    last_entry=$(tail -n 1 "$LOGFILE" 2>/dev/null)
    if [ -n "$last_entry" ]; then
        last_time="${last_entry% | *}"
        last_text="${last_entry#* | }"
        printf '<div class="entry"><div class="ts">%s</div><div class="text">%s</div></div>\n' \
            "$(html_escape "$last_time")" "$(html_escape "$last_text")"
    else
        printf '<div class="empty">no entries yet — write the first one</div>\n'
    fi
fi

cat <<'HTML_FOOTER'
<div class="footer">ymawky :: hand-rolled aarch64 :: logbook v0.3</div>
</div>
</body>
</html>
HTML_FOOTER
